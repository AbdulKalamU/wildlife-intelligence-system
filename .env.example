# Wildlife Monitoring System - Environment Variables
# Copy this file to .env and configure your settings

# Model Paths
YOLO_MODEL_PATH=yolov8n.pt
CLASSIFIER_MODEL_PATH=

# Detection Settings
DETECTION_CONFIDENCE=0.5
DETECTION_IOU=0.45

# Classification Settings
CLASSIFICATION_CONFIDENCE=0.6

# Tracking Settings
MAX_DISAPPEARED_FRAMES=50

# Analytics Settings
TREND_WINDOW_HOURS=24
RISK_ASSESSMENT_ENABLED=true

# Alert Settings
ALERT_ENABLED=true
ENDANGERED_SPECIES=Wolf,Bear

# Dashboard Settings
DASHBOARD_PORT=8501
DASHBOARD_REFRESH_RATE=1.0

# Video Processing
VIDEO_FRAME_SKIP=1
VIDEO_RESIZE_WIDTH=0
VIDEO_RESIZE_HEIGHT=0

# Logging
LOG_LEVEL=INFO
LOG_FILE=wildlife_monitoring.log

# Export Settings
EXPORT_FORMAT=json
EXPORT_DETECTIONS=true
EXPORT_TRACKS=true
EXPORT_ANALYTICS=true
